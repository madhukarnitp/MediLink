# Server
NODE_ENV=production
PORT=5001
CLIENT_URL=https://your-frontend.onrender.com
API_BASE_URL=https://your-backend.onrender.com

# MongoDB
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/medilink
MONGODB_URI_TEST=mongodb://127.0.0.1:27017/medilink_test

# JWT
JWT_SECRET=replace-with-64-byte-random-hex
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d

# CORS
ALLOWED_ORIGINS=https://your-frontend.onrender.com,http://localhost:3000,http://localhost:5173

# Realtime bridge
REALTIME_SERVER_URL=https://your-realtime.onrender.com
REALTIME_INTERNAL_SECRET=replace-with-random-realtime-bridge-secret
REALTIME_BRIDGE_TIMEOUT_MS=1200

# Email
DISABLE_EMAIL=false
EMAIL_REQUIRED=false
RESEND_API_KEY=your_resend_api_key
EMAIL_FROM=MediLink <onboarding@resend.dev>

# AI
OPENAI_API_KEY=
AI_API_KEY=
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Prescription verification links
PRESCRIPTION_VERIFY_SECRET=replace-with-random-prescription-secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=150
