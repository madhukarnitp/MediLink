NODE_ENV=production
PORT=5002
REALTIME_PORT=5002

MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER/medilink
JWT_SECRET=use-the-same-value-as-backend-jwt-secret
ALLOWED_ORIGINS=https://medilink-olive.vercel.app,http://localhost:5173,http://localhost:3000
REALTIME_ALLOWED_ORIGINS=https://medilink-olive.vercel.app,http://localhost:5173,http://localhost:3000
REALTIME_INTERNAL_SECRET=use-the-same-value-as-backend-realtime-internal-secret

REALTIME_PING_TIMEOUT_MS=30000
REALTIME_PING_INTERVAL_MS=25000
REALTIME_CONNECT_TIMEOUT_MS=10000
REALTIME_MAX_BUFFER_SIZE=1000000
REALTIME_MAX_CONNECTIONS_PER_USER=3
REALTIME_CONSULTATION_CACHE_TTL_MS=300000
